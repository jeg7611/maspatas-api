{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Launch (MasPatas.API)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/MasPatas.API/bin/Debug/net8.0/MasPatas.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/MasPatas.API",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Now listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
